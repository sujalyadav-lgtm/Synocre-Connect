rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }
    
    function isManager() {
      return isAuthenticated() && (getUserRole() == 'manager' || getUserRole() == 'admin');
    }
    
    function isStaff() {
      return isAuthenticated() && (getUserRole() == 'staff' || getUserRole() == 'manager' || getUserRole() == 'admin');
    }

    // Rules per collection
    
    match /users/{userId} {
      // Users can read their own profile; admins can read/write all users
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    match /products/{productId} {
      allow read: if isStaff();
      // Managers and Admins can create/update, but only Admins can delete
      allow create, update: if isManager();
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isStaff();
      allow create, update: if isManager();
      allow delete: if isAdmin();
    }
  }
}
